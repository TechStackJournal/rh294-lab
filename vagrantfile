# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# RH294 Lab Environment
# Topology: 1 control node + 3 managed nodes (RHEL 9)
#
# Prerequisites:
#   vagrant plugin install vagrant-hostmanager
#   Red Hat Developer account (for RHEL 9 box) OR use AlmaLinux 9 (free)
#
# Usage:
#   vagrant up              # Boot all VMs
#   vagrant ssh control     # SSH into control node
#   vagrant halt            # Stop all VMs
#   vagrant destroy -f      # Destroy all VMs

BOX_IMAGE = "almalinux/9"   # Free RHEL-compatible. Swap for "generic/rhel9" if licensed.
DOMAIN    = "lab.example.com"

NODES = [
  { name: "control",  ip: "192.168.56.10", memory: 2048, cpus: 2 },
  { name: "node1",    ip: "192.168.56.11", memory: 1024, cpus: 1 },
  { name: "node2",    ip: "192.168.56.12", memory: 1024, cpus: 1 },
  { name: "node3",    ip: "192.168.56.13", memory: 1024, cpus: 1 },
]

Vagrant.configure("2") do |config|

  config.hostmanager.enabled      = true
  config.hostmanager.manage_host  = false
  config.hostmanager.manage_guest = true
  config.hostmanager.ignore_private_ip = false

  NODES.each do |node|
    config.vm.define node[:name] do |cfg|
      cfg.vm.box      = BOX_IMAGE
      cfg.vm.hostname = "#{node[:name]}.#{DOMAIN}"

      cfg.vm.network "private_network", ip: node[:ip]

      cfg.vm.provider "virtualbox" do |vb|
        vb.name   = "rh294-#{node[:name]}"
        vb.memory = node[:memory]
        vb.cpus   = node[:cpus]
      end

      # --- Control node bootstrap ---
      if node[:name] == "control"
        cfg.vm.provision "shell", inline: <<-SHELL
          echo "==> Installing Ansible on control node"
          dnf install -y python3-pip
          pip3 install ansible

          echo "==> Generating SSH keypair for ansible user"
          useradd -m ansible 2>/dev/null || true
          echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible
          su - ansible -c "ssh-keygen -t ed25519 -N '' -f ~/.ssh/id_ed25519" 2>/dev/null || true

          echo "==> Writing ansible.cfg"
          cat > /home/ansible/ansible.cfg <<'EOF'
[defaults]
inventory         = /home/ansible/inventory/hosts.ini
remote_user       = ansible
host_key_checking = False
roles_path        = /home/ansible/roles

[privilege_escalation]
become        = True
become_method = sudo
become_user   = root
become_ask_pass = False
EOF
          chown ansible:ansible /home/ansible/ansible.cfg

          echo "==> Writing static inventory"
          mkdir -p /home/ansible/inventory
          cat > /home/ansible/inventory/hosts.ini <<'EOF'
[all:vars]
ansible_user=ansible
ansible_ssh_private_key_file=~/.ssh/id_ed25519

[control]
control.lab.example.com ansible_connection=local

[managed]
node1.lab.example.com ansible_host=192.168.56.11
node2.lab.example.com ansible_host=192.168.56.12
node3.lab.example.com ansible_host=192.168.56.13

[webservers]
node1.lab.example.com
node2.lab.example.com

[dbservers]
node3.lab.example.com
EOF
          chown -R ansible:ansible /home/ansible/inventory

          echo "==> Control node provisioning complete."
          echo "    Next step: run 'vagrant provision' or push SSH keys to managed nodes."
        SHELL
      else
        # --- Managed node bootstrap ---
        cfg.vm.provision "shell", inline: <<-SHELL
          echo "==> Creating ansible user on managed node"
          useradd -m ansible 2>/dev/null || true
          echo "ansible ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/ansible
          mkdir -p /home/ansible/.ssh
          chmod 700 /home/ansible/.ssh
          chown -R ansible:ansible /home/ansible/.ssh
          echo "==> Managed node $(hostname) ready."
        SHELL
      end

    end
  end

end
